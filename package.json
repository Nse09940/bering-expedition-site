{
  "name": "bering-expedition-site",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:docs": "pnpm --filter apps-docs start",
    "build:web": "pnpm --filter web build",
    "build:docs": "pnpm --filter apps-docs build",
    "lint:web": "pnpm --filter web lint",
    "format": "pnpm exec prettier --write .",
    "format:check": "pnpm exec prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css,yml,yaml}": [
      "pnpm exec prettier --write"
    ]
  }
}
